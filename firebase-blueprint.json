{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "TaskList": {
      "title": "TaskList",
      "description": "A collection of tasks, potentially shared",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": {
          "type": "object",
          "description": "Map of userId to role (owner, editor, viewer)"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "ownerId", "members"]
    },
    "Task": {
      "title": "Task",
      "description": "A single task item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "creatorId": { "type": "string" },
        "assigneeId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "reminderAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "creatorId", "priority", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/lists/{listId}": {
      "schema": "TaskList",
      "description": "Collaborative task lists"
    },
    "/lists/{listId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks within a specific list"
    }
  }
}
